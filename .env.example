# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=einv
POSTGRES_PASSWORD=einv_pass
POSTGRES_DB=einvoice
DATABASE_URL=postgresql+asyncpg://einv:einv_pass@postgres:5432/einvoice
DATABASE_POOL_MIN=5
DATABASE_POOL_MAX=20

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_RAW=e-invoice-raw
MINIO_BUCKET_PROCESSED=e-invoice-processed
MINIO_BUCKET_MODELS=e-invoice-models
MINIO_USE_SSL=false

# ── Auth ──────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Claude API (LLM fallback) ─────────────────────────────────────────────────
CLAUDE_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_TIMEOUT_SECONDS=30
CLAUDE_MAX_RETRIES=2

# ── OCR ───────────────────────────────────────────────────────────────────────
OCR_THREAD_POOL_SIZE=4
OCR_DEFAULT_CONFIDENCE_THRESHOLD=0.95
OCR_MODEL_DIR=/app/model_registry

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
MAX_UPLOAD_SIZE_MB=50
ALLOWED_MIME_TYPES=application/pdf,text/xml,application/xml,image/jpeg,image/png,image/tiff
